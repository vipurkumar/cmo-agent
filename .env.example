# LLM
CMO_ANTHROPIC_API_KEY=sk-ant-xxx
CMO_CLAUDE_MODEL=claude-sonnet-4-6
CMO_CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Database (points to PgBouncer, NOT PostgreSQL directly)
CMO_DATABASE_URL=postgresql+asyncpg://cmo:cmo_secret@localhost:6432/cmo

# Redis
CMO_REDIS_URL=redis://localhost:6379/0
CMO_REDIS_KEY_PREFIX=cmo:

# ClickHouse
CMO_CLICKHOUSE_URL=clickhouse://localhost:9000/cmo

# n8n
CMO_HMAC_SECRET=change-me-to-a-random-secret
CMO_N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# Agent defaults
CMO_MAX_ACCOUNTS_PER_BATCH=20
CMO_SEQUENCE_MAX_STAGES=3

# External APIs
CMO_APOLLO_API_KEY=
CMO_APOLLO_BASE_URL=https://api.apollo.io/v1
CMO_CLAY_API_KEY=
CMO_CLAY_BASE_URL=https://api.clay.com/v1
CMO_LINKEDIN_API_KEY=
CMO_HUBSPOT_API_KEY=
CMO_ZOHO_CLIENT_ID=
CMO_ZOHO_CLIENT_SECRET=
CMO_ZOHO_REFRESH_TOKEN=
CMO_SLACK_BOT_TOKEN=xoxb-xxx
CMO_SLACK_SIGNING_SECRET=

# Embeddings
CMO_EMBEDDING_PROVIDER=anthropic
CMO_EMBEDDING_MODEL=voyage-3
CMO_EMBEDDING_DIMENSIONS=1024
CMO_OPENAI_API_KEY=

# Feature flags
CMO_USE_APOLLO_ENRICHMENT=true
CMO_APOLLO_MCP_ENABLED=false
CMO_DEMO_MODE=false
CMO_ADMIN_API_KEY=change-me-to-admin-secret

# Server
CMO_HOST=0.0.0.0
CMO_PORT=8000
CMO_LOG_LEVEL=info
