{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(cmo_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cmo_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cmo_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(cmo_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "LLM Cost (USD/hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(cmo_llm_cost_usd_total[1h])) by (model) * 3600",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "title": "LLM Calls by Task",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(cmo_llm_calls_total[5m])) by (task)",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "LLM Token Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(cmo_llm_tokens_total[5m])) by (direction, model)",
          "legendFormat": "{{direction}} - {{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "LLM Call Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cmo_llm_call_duration_seconds_bucket[5m])) by (le, task))",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Job Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(cmo_jobs_total[5m])) by (job_type, status)",
          "legendFormat": "{{job_type}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Job Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cmo_job_duration_seconds_bucket[5m])) by (le, job_type))",
          "legendFormat": "{{job_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Jobs In Progress",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(cmo_jobs_in_progress) by (queue)",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limit Rejections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 32 },
      "targets": [
        {
          "expr": "sum(increase(cmo_rate_limit_hits_total[1h]))",
          "legendFormat": "Last hour",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum(increase(cmo_auth_failures_total[1h]))",
          "legendFormat": "Last hour",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Automation Pauses",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 32 },
      "targets": [
        {
          "expr": "sum(increase(cmo_automation_pauses_total[24h]))",
          "legendFormat": "Last 24h",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Accounts Scored by Action",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum(cmo_accounts_scored_total) by (action)",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Briefs Generated",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "targets": [
        {
          "expr": "sum(rate(cmo_briefs_generated_total[1h])) * 3600",
          "legendFormat": "briefs/hour",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Send Cap Hits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "targets": [
        {
          "expr": "sum(rate(cmo_send_cap_hits_total[1h])) by (cap_type) * 3600",
          "legendFormat": "{{cap_type}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cmo-agent"],
  "templating": {
    "list": [
      {
        "name": "workspace_id",
        "type": "query",
        "query": "label_values(cmo_http_requests_total, workspace_id)",
        "datasource": "Prometheus",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "CMO Agent Overview",
  "uid": "cmo-agent-overview"
}
